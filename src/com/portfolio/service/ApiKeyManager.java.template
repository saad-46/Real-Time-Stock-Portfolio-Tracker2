package com.portfolio.service;

/**
 * ApiKeyManager - Centralized API key configuration for all services.
 * All keys are stored here to avoid scattering them across multiple files.
 * 
 * SETUP INSTRUCTIONS:
 * 1. Copy this file to ApiKeyManager.java
 * 2. Replace all "YOUR_KEY_HERE" with actual API keys
 * 3. Never commit ApiKeyManager.java with real keys!
 */
public class ApiKeyManager {

    // ==================== STOCK PRICE APIs ====================
    
    // Finnhub (Primary) - 60 calls/min free tier
    // Get free key: https://finnhub.io/register
    private static final String[] FINNHUB_KEYS = {
        "YOUR_FINNHUB_KEY_1",
        "YOUR_FINNHUB_KEY_2"  // Optional: Add more keys for higher rate limits
    };
    private static int finnhubKeyIndex = 0;

    // Twelve Data (Secondary) - 800 calls/day free tier
    // Get free key: https://twelvedata.com/pricing
    private static final String TWELVE_DATA_KEY = "YOUR_TWELVE_DATA_KEY";

    // Alpha Vantage (Fallback) - 25 calls/day free tier
    // Get free key: https://www.alphavantage.co/support/#api-key
    private static final String ALPHA_VANTAGE_KEY = "YOUR_ALPHA_VANTAGE_KEY";

    // ==================== NEWS APIs ====================
    
    // GNews (Primary) - 100 requests/day free tier
    // Get free key: https://gnews.io/register
    private static final String GNEWS_KEY = "YOUR_GNEWS_KEY";

    // NewsData.io (Fallback) - 200 credits/day free tier
    // Get free key: https://newsdata.io/register
    private static final String NEWSDATA_KEY = "YOUR_NEWSDATA_KEY";

    // ==================== AI & VOICE APIs ====================
    
    // Groq AI - LLM for chat & portfolio analysis
    // Get free key: https://console.groq.com/keys
    private static final String GROQ_KEY = "YOUR_GROQ_KEY";

    // AssemblyAI - Speech-to-Text
    // Get free key: https://www.assemblyai.com/dashboard/signup
    private static final String ASSEMBLYAI_KEY = "YOUR_ASSEMBLYAI_KEY";

    // ==================== GETTERS ====================

    /** Get next Finnhub key (round-robin for higher rate limits) */
    public static synchronized String getFinnhubKey() {
        String key = FINNHUB_KEYS[finnhubKeyIndex];
        finnhubKeyIndex = (finnhubKeyIndex + 1) % FINNHUB_KEYS.length;
        return key;
    }

    public static String getTwelveDataKey() {
        return TWELVE_DATA_KEY;
    }

    public static String getAlphaVantageKey() {
        return ALPHA_VANTAGE_KEY;
    }

    public static String getGNewsKey() {
        return GNEWS_KEY;
    }

    public static String getNewsDataKey() {
        return NEWSDATA_KEY;
    }

    public static String getGroqKey() {
        return GROQ_KEY;
    }

    public static String getAssemblyAIKey() {
        return ASSEMBLYAI_KEY;
    }
}
